{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "namePrefix": {
      "value": "flogoagent"
    },
    "location": {
      "value": "eastus"
    },
    "postgresAdminUsername": {
      "value": "flogoadmin"
    },
    "postgresAdminPassword": {
      "value": "replace-me"
    },
    "controlPlaneImage": {
      "value": "myregistry.azurecr.io/flogo-agent/control-plane:latest"
    },
    "orchestratorImage": {
      "value": "myregistry.azurecr.io/flogo-agent/orchestrator:latest"
    },
    "runnerWorkerImage": {
      "value": "myregistry.azurecr.io/flogo-agent/runner-worker:latest"
    },
    "webConsoleImage": {
      "value": "myregistry.azurecr.io/flogo-agent/web-console:latest"
    },
    "runnerJobImage": {
      "value": "myregistry.azurecr.io/flogo-agent/flogo-runner:latest"
    }
  }
}
