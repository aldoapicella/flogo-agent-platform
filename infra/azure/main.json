    "runnerJobName": {
      "type": "string",
      "value": "[format('{0}-flogo-runner', parameters('namePrefix'))]"
    },
    "storageAccountName": {
      "type": "string",
      "value": "[variables('storageName')]"
    },
    "keyVaultName": {
      "type": "string",
      "value": "[variables('keyVaultName')]"
    }
  }
}