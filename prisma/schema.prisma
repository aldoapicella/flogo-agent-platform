generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskType {
  create
  update
  debug
  review
}

enum TaskStatus {
  queued
  planning
  running
  awaiting_approval
  succeeded
  failed
  cancelled
}

enum TaskStepStatus {
  pending
  running
  succeeded
  failed
}

enum ApprovalType {
  delete_resource
  delete_flow
  dependency_upgrade
  custom_code
  external_endpoint_change
  public_contract_change
  deploy
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum ArtifactKind {
  diff
  binary
  build_log
  runtime_log
  report
  snapshot
  readme
}

model Organization {
  id        String    @id @default(uuid())
  name      String
  projects  Project[]
  createdAt DateTime  @default(now())
}

model Project {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  repoUrl        String
  defaultBranch  String       @default("main")
  apps           FlogoApp[]
  tasks          Task[]
  createdAt      DateTime     @default(now())
}

model FlogoApp {
  id            String        @id @default(uuid())
  projectId     String
  project       Project       @relation(fields: [projectId], references: [id])
  appName       String
  appPath       String
  appType       String        @default("flogo:app")
  appModel      String
  lastKnownHash String?
  imports       AppImport[]
  triggers      AppTrigger[]
  resources     AppResource[]
  tasks         Task[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Task {
  id           String              @id @default(uuid())
  projectId    String
  project      Project             @relation(fields: [projectId], references: [id])
  flogoAppId   String?
  flogoApp     FlogoApp?           @relation(fields: [flogoAppId], references: [id])
  type         TaskType
  status       TaskStatus
  requestedBy  String
  prompt       String
  inputPayload Json
  planSummary  String?
  riskScore    Decimal?
  steps        TaskStep[]
  events       TaskEvent[]
  toolCalls    ToolCall[]
  approvals    Approval[]
  snapshots    WorkspaceSnapshot[]
  patches      Patch[]
  buildRuns    BuildRun[]
  testRuns     TestRun[]
  artifacts    Artifact[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model TaskStep {
  id         String         @id @default(uuid())
  taskId     String
  task       Task           @relation(fields: [taskId], references: [id])
  stepOrder  Int
  type       String
  status     TaskStepStatus
  summary    String?
  startedAt  DateTime?
  finishedAt DateTime?
}

model TaskEvent {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
  type      String
  payload   Json
  createdAt DateTime @default(now())
}

model ToolCall {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
  toolName  String
  request   Json
  response  Json?
  success   Boolean?
  latencyMs Int?
  createdAt DateTime @default(now())
}

model Approval {
  id            String         @id @default(uuid())
  taskId        String
  task          Task           @relation(fields: [taskId], references: [id])
  type          ApprovalType
  status        ApprovalStatus
  rationale     String
  requestedFrom String
  respondedAt   DateTime?
  createdAt     DateTime       @default(now())
}

model WorkspaceSnapshot {
  id          String   @id @default(uuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id])
  repoCommit  String?
  branchName  String
  snapshotUri String
  createdAt   DateTime @default(now())
}

model Patch {
  id          String   @id @default(uuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id])
  filePath    String
  patchFormat String   @default("unified_diff")
  patchText   String
  applied     Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model BuildRun {
  id          String   @id @default(uuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id])
  jobId       String
  commandLine String
  status      String
  binaryUri   String?
  logUri      String?
  exitCode    Int?
  startedAt   DateTime?
  finishedAt  DateTime?
  testRuns    TestRun[]
}

model TestRun {
  id         String    @id @default(uuid())
  taskId     String
  task       Task      @relation(fields: [taskId], references: [id])
  buildRunId String?
  buildRun   BuildRun? @relation(fields: [buildRunId], references: [id])
  type       String
  status     String
  reportUri  String?
  summary    Json?
  startedAt  DateTime?
  finishedAt DateTime?
}

model Artifact {
  id        String       @id @default(uuid())
  taskId    String
  task      Task         @relation(fields: [taskId], references: [id])
  kind      ArtifactKind
  name      String
  uri       String
  createdAt DateTime     @default(now())
}

model KnowledgeChunk {
  id         String   @id @default(uuid())
  sourceType String
  sourceUri  String
  title      String?
  chunkText  String
  metadata   Json
  createdAt  DateTime @default(now())
}

model PromptVersion {
  id        String   @id @default(uuid())
  promptId  String
  version   String
  role      String
  content   Json
  createdAt DateTime @default(now())
}

model EvalRun {
  id         String   @id @default(uuid())
  suite      String
  version    String
  summary    Json
  startedAt  DateTime?
  finishedAt DateTime?
}

model AppImport {
  id         String   @id @default(uuid())
  flogoAppId String
  flogoApp   FlogoApp @relation(fields: [flogoAppId], references: [id])
  alias      String
  ref        String
}

model AppTrigger {
  id         String       @id @default(uuid())
  flogoAppId String
  flogoApp   FlogoApp     @relation(fields: [flogoAppId], references: [id])
  triggerId  String
  ref        String
  settings   Json
  handlers   AppHandler[]
}

model AppHandler {
  id             String     @id @default(uuid())
  triggerId      String
  trigger        AppTrigger @relation(fields: [triggerId], references: [id])
  handlerIndex   Int
  settings       Json
  actionRef      String
  inputMappings  Json?
  outputMappings Json?
}

model AppResource {
  id           String   @id @default(uuid())
  flogoAppId   String
  flogoApp     FlogoApp @relation(fields: [flogoAppId], references: [id])
  resourceId   String
  resourceType String
  body         Json
}
