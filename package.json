{
  "name": "flogo-agent-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.14.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 --if-present build",
    "typecheck": "pnpm -r --workspace-concurrency=1 --if-present typecheck",
    "test": "pnpm -r --workspace-concurrency=1 --if-present test",
    "db:generate": "prisma generate",
    "compose:up": "docker compose -f infra/local/docker-compose.yml up --build",
    "compose:down": "docker compose -f infra/local/docker-compose.yml down -v"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prisma": "^6.6.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
