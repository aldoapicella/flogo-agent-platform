{
  "name": "flogo-agent-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.14.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 --if-present build",
    "typecheck": "pnpm -r --workspace-concurrency=1 --if-present typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "dev:control-plane": "pnpm --filter @flogo-agent/control-plane dev",
    "dev:runner-worker": "pnpm --filter @flogo-agent/runner-worker dev",
    "dev:web": "pnpm --filter @flogo-agent/web-console dev",
    "dev": "concurrently -n control-plane,runner-worker,web -c blue,green,magenta \"pnpm dev:control-plane\" \"pnpm dev:runner-worker\" \"pnpm dev:web\"",
    "compose:up": "docker compose -f infra/local/docker-compose.yml up --build",
    "compose:down": "docker compose -f infra/local/docker-compose.yml down --remove-orphans"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.2",
    "@types/diff": "^7.0.1",
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^3.0.8",
    "concurrently": "^9.1.2",
    "prisma": "^6.4.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
