{
  "version": "2.0",
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  },
  "extensions": {
    "durableTask": {
      "hubName": "%DURABLE_TASK_HUB_NAME%",
      "storageProvider": {
        "type": "%DURABLE_STORAGE_PROVIDER_TYPE%",
        "connectionStringName": "%DURABLE_BACKEND_CONNECTION_NAME%"
      }
    }
  }
}
