{
  "name": "@flogo-agent/agent",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@flogo-agent/contracts": "workspace:*",
    "@flogo-agent/flogo-graph": "workspace:*",
    "@flogo-agent/prompts": "workspace:*",
    "@flogo-agent/tools": "workspace:*"
  }
}

