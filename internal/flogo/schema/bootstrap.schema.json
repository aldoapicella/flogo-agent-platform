{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bootstrap Flogo Descriptor Schema",
  "type": "object",
  "required": [
    "name",
    "type",
    "version",
    "description",
    "imports",
    "properties",
    "channels",
    "triggers",
    "resources",
    "actions"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "imports": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "properties": {
      "type": "array"
    },
    "channels": {
      "type": "array"
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
