{
  "name": "broken-mappings",
  "type": "flogo:app",
  "appModel": "1.1.0",
  "imports": [],
  "triggers": [
    {
      "id": "rest",
      "ref": "#rest",
      "settings": {
        "port": 8081
      },
      "handlers": [
        {
          "id": "broken-handler",
          "settings": {
            "method": "GET",
            "path": "/broken"
          },
          "action": {
            "ref": "flow:missing"
          }
        }
      ]
    }
  ],
  "resources": {
    "broken-flow": {
      "type": "flow",
      "data": {
        "metadata": {
          "input": [],
          "output": []
        },
        "tasks": [
          {
            "id": "log-request",
            "name": "log-request",
            "activity": {
              "ref": "#log"
            },
            "input": {
              "message": "=$activity[missing].message"
            }
          }
        ]
      }
    }
  }
}
